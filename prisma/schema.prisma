generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  user
}

enum AppStatus {
  developing
  stopped
  building
  running
  error
}

enum ServiceType {
  // database
  postgresql
  mysql
  mongodb
  // storage
  s3
  gcs
  azure_blob
  google_drive
  // payment
  stripe
  paypal
  ecpay
  // email
  sendgrid
  ses
  mailgun
  // sms
  twilio
  vonage
  aws_sns
  // auth
  auth0
  firebase_auth
  line_login
  // platform
  supabase
  hasura
  // chat
  line_bot
  whatsapp
  discord
  telegram
  // built-in (platform-managed infrastructure)
  built_in_real_estate
  built_in_supabase
  built_in_keycloak
  built_in_minio
  built_in_n8n
  built_in_qdrant
  built_in_meilisearch
  built_in_posthog
  built_in_metabase
  built_in_accounting
  built_in_auto_repair
  built_in_beauty
  built_in_cleaning
  built_in_education
  built_in_fitness
  built_in_hospitality
  built_in_legal
  built_in_logistics
  built_in_medical
  built_in_pet_care
  built_in_photography
  built_in_realestate
  built_in_restaurant
  built_in_retail
  // ai_model
  openai
  gemini
  claude
  openrouter
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users           User[]
  services        Service[]
  allowedServices OrgAllowedService[]
  domains         OrgDomain[]
  chatFiles       ChatFile[]

  @@map("organizations")
}

model OrgAllowedService {
  id             String      @id @default(cuid())
  organizationId String      @map("organization_id")
  serviceType    ServiceType @map("service_type")
  enabled        Boolean     @default(true)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, serviceType])
  @@map("org_allowed_services")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  passwordHash   String   @map("password_hash")
  role           UserRole @default(user)
  organizationId String   @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  apps            App[]
  chatMessages    ChatMessage[]
  chatFiles       ChatFile[]
  allowedServices UserAllowedServiceInstance[]

  @@map("users")
}

model App {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  template    String
  status      AppStatus @default(developing)
  port        Int?
  prodPort    Int?      @map("prod_port")
  config      Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // k8s resource management
  memoryLimitMb  Int?     @map("memory_limit_mb")
  cpuLimitMillis Int?     @map("cpu_limit_millis")
  autoScale      Boolean  @default(false) @map("auto_scale")
  maxReplicas    Int      @default(1) @map("max_replicas")

  services     AppService[]
  chatMessages ChatMessage[]
  artifacts    AgentArtifact[]
  deployments  Deployment[]

  @@map("apps")
}

model OrgDomain {
  id        String   @id @default(cuid())
  domain    String   @unique
  isActive  Boolean  @default(false) @map("is_active")
  sslStatus String   @default("pending") @map("ssl_status")
  createdAt DateTime @default(now()) @map("created_at")

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("org_domains")
}

model Service {
  id             String      @id @default(cuid())
  name           String
  type           ServiceType
  endpointUrl    String?     @map("endpoint_url")
  configEncrypted String     @map("config_encrypted")
  iv             String
  authTag        String      @map("auth_tag")
  organizationId String      @map("organization_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  apps          AppService[]
  allowedUsers  UserAllowedServiceInstance[]

  @@map("services")
}

model UserAllowedServiceInstance {
  id        String @id @default(cuid())
  userId    String @map("user_id")
  serviceId String @map("service_id")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceId])
  @@map("user_allowed_service_instances")
}

model AppService {
  appId        String @map("app_id")
  serviceId    String @map("service_id")
  envVarPrefix String @default("SVC") @map("env_var_prefix")

  app     App     @relation(fields: [appId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([appId, serviceId])
  @@map("app_services")
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String
  content   String
  agentRole String?  @map("agent_role")
  stage     String?
  createdAt DateTime @default(now()) @map("created_at")

  appId  String? @map("app_id")
  app    App?    @relation(fields: [appId], references: [id], onDelete: Cascade)

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  conversationId String? @map("conversation_id")

  @@map("chat_messages")
}

/// Persists structured outputs from agents (design docs, task specs, etc.)
/// so they can be referenced across agent calls without repeating in context.
model AgentArtifact {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  agentRole      String   @map("agent_role")
  type           String   // "design" | "spec" | "review" | "deployment" | "task"
  content        Json     // the structured JSON output from the agent
  actorId        String?  @map("actor_id")  // actor instance ID (e.g. "developer-0")
  taskId         String?  @map("task_id")   // parallel task identifier
  createdAt      DateTime @default(now()) @map("created_at")

  appId String? @map("app_id")
  app   App?    @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([conversationId, agentRole])
  @@map("agent_artifacts")
}

model ChatFile {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  fileName       String   @map("file_name")
  fileType       String   @map("file_type") // "image" | "text" | "pdf" | "code" | "unknown"
  mimeType       String   @map("mime_type")
  sizeBytes      Int      @map("size_bytes")
  storagePath      String   @map("storage_path")
  extractedText    String?  @map("extracted_text") @db.Text
  summary          String?  @db.Text
  status           String   @default("uploaded") // "uploaded" | "processing" | "ready" | "error"
  importSessionId  String?  @map("import_session_id")
  relativePath     String?  @map("relative_path")
  createdAt        DateTime @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
  @@index([importSessionId])
  @@map("chat_files")
}

model Deployment {
  id        String   @id @default(cuid())
  appId     String   @map("app_id")
  status    String   // "building" | "running" | "failed" | "stopped" | "rolledBack"
  buildLog  String?  @map("build_log")
  imageTag  String?  @map("image_tag")
  version   Int
  createdAt DateTime @default(now()) @map("created_at")

  app App @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId, version])
  @@map("deployments")
}

// Note: "content_chunks" table is managed via raw SQL (pgvector).
// See migration 20260328170000 and src/lib/vector-search.ts.
