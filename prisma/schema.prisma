generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  user
}

enum AppStatus {
  developing
  stopped
  building
  running
  error
}

enum ServiceType {
  // database
  postgresql
  mysql
  mongodb
  // storage
  s3
  gcs
  azure_blob
  google_drive
  // payment
  stripe
  paypal
  ecpay
  // email
  sendgrid
  ses
  mailgun
  // sms
  twilio
  vonage
  aws_sns
  // auth
  auth0
  firebase_auth
  line_login
  // platform
  supabase
  hasura
  // chat
  line_bot
  whatsapp
  discord
  telegram
  // built-in (platform-managed)
  built_in_pg
  built_in_disk
  built_in_real_estate
  // ai_model
  openai
  gemini
  claude
  openrouter
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users           User[]
  services        Service[]
  allowedServices OrgAllowedService[]
  domains         OrgDomain[]

  @@map("organizations")
}

model OrgAllowedService {
  id             String      @id @default(cuid())
  organizationId String      @map("organization_id")
  serviceType    ServiceType @map("service_type")
  enabled        Boolean     @default(true)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, serviceType])
  @@map("org_allowed_services")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  passwordHash   String   @map("password_hash")
  role           UserRole @default(user)
  organizationId String   @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  apps            App[]
  chatMessages    ChatMessage[]
  allowedServices UserAllowedServiceInstance[]

  @@map("users")
}

model App {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  template    String
  status      AppStatus @default(developing)
  port        Int?
  prodPort    Int?      @map("prod_port")
  config      Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  services     AppService[]
  chatMessages ChatMessage[]
  pipelines    AgentPipeline[]
  deployments  Deployment[]

  @@map("apps")
}

model OrgDomain {
  id        String   @id @default(cuid())
  domain    String   @unique
  isActive  Boolean  @default(false) @map("is_active")
  sslStatus String   @default("pending") @map("ssl_status")
  createdAt DateTime @default(now()) @map("created_at")

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("org_domains")
}

model Service {
  id             String      @id @default(cuid())
  name           String
  type           ServiceType
  endpointUrl    String?     @map("endpoint_url")
  configEncrypted String     @map("config_encrypted")
  iv             String
  authTag        String      @map("auth_tag")
  organizationId String      @map("organization_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  apps          AppService[]
  allowedUsers  UserAllowedServiceInstance[]

  @@map("services")
}

model UserAllowedServiceInstance {
  id        String @id @default(cuid())
  userId    String @map("user_id")
  serviceId String @map("service_id")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceId])
  @@map("user_allowed_service_instances")
}

model AppService {
  appId        String @map("app_id")
  serviceId    String @map("service_id")
  envVarPrefix String @default("SVC") @map("env_var_prefix")

  app     App     @relation(fields: [appId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([appId, serviceId])
  @@map("app_services")
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String
  content   String
  agentRole String?  @map("agent_role")
  stage     String?
  createdAt DateTime @default(now()) @map("created_at")

  appId  String? @map("app_id")
  app    App?    @relation(fields: [appId], references: [id], onDelete: Cascade)

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  pipelineId String?        @map("pipeline_id")
  pipeline   AgentPipeline? @relation(fields: [pipelineId], references: [id], onDelete: SetNull)

  @@map("chat_messages")
}

model AgentPipeline {
  id              String   @id @default(cuid())
  status          String   @default("idle")
  currentAgent    String?  @map("current_stage")
  completedAgents String[] @map("completed_stages")
  tasks           Json?    @map("stage_data")
  parallelGroups  Json?    @map("parallel_groups")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  appId String? @map("app_id")
  app   App?    @relation(fields: [appId], references: [id], onDelete: Cascade)

  messages  ChatMessage[]
  artifacts AgentArtifact[]

  @@map("agent_pipelines")
}

/// Persists structured outputs from agents (design docs, task specs, etc.)
/// so they can be referenced across agent calls without repeating in context.
model AgentArtifact {
  id         String   @id @default(cuid())
  pipelineId String   @map("pipeline_id")
  agentRole  String   @map("agent_role")
  type       String   // "design" | "spec" | "review" | "deployment" | "task"
  content    Json     // the structured JSON output from the agent
  actorId    String?  @map("actor_id")  // actor instance ID (e.g. "developer-0")
  taskId     String?  @map("task_id")   // parallel task identifier
  createdAt  DateTime @default(now()) @map("created_at")

  pipeline AgentPipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@index([pipelineId, agentRole])
  @@map("agent_artifacts")
}

model Deployment {
  id        String   @id @default(cuid())
  appId     String   @map("app_id")
  status    String   // "building" | "running" | "failed" | "stopped" | "rolledBack"
  buildLog  String?  @map("build_log")
  imageTag  String?  @map("image_tag")
  version   Int
  createdAt DateTime @default(now()) @map("created_at")

  app App @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId, version])
  @@map("deployments")
}
