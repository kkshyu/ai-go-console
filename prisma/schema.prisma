generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  user
}

enum AppStatus {
  developing
  stopped
  building
  running
  error
}

enum ServiceType {
  disk
  postgresql
  supabase
  stripe
  hasura
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users           User[]
  services        Service[]
  allowedServices OrgAllowedService[]

  @@map("organizations")
}

model OrgAllowedService {
  id             String      @id @default(cuid())
  organizationId String      @map("organization_id")
  serviceType    ServiceType @map("service_type")
  enabled        Boolean     @default(true)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, serviceType])
  @@map("org_allowed_services")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  passwordHash   String   @map("password_hash")
  role           UserRole @default(user)
  organizationId String   @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  apps         App[]
  chatMessages ChatMessage[]

  @@map("users")
}

model App {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  template    String
  status      AppStatus @default(developing)
  port        Int?
  config      Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  domains      AppDomain[]
  services     AppService[]
  chatMessages ChatMessage[]

  @@map("apps")
}

model AppDomain {
  id        String   @id @default(cuid())
  domain    String   @unique
  isActive  Boolean  @default(false) @map("is_active")
  sslStatus String   @default("pending") @map("ssl_status")
  createdAt DateTime @default(now()) @map("created_at")

  appId String @map("app_id")
  app   App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@map("app_domains")
}

model Service {
  id             String      @id @default(cuid())
  name           String
  type           ServiceType
  endpointUrl    String?     @map("endpoint_url")
  configEncrypted String     @map("config_encrypted")
  iv             String
  authTag        String      @map("auth_tag")
  organizationId String      @map("organization_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  apps         AppService[]

  @@map("services")
}

model AppService {
  appId        String @map("app_id")
  serviceId    String @map("service_id")
  envVarPrefix String @default("SVC") @map("env_var_prefix")

  app     App     @relation(fields: [appId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([appId, serviceId])
  @@map("app_services")
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  appId  String? @map("app_id")
  app    App?    @relation(fields: [appId], references: [id], onDelete: Cascade)

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("chat_messages")
}
