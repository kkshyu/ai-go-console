# ============================================================
# AI Go Console - Environment Variables
# ============================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
# .env is in .gitignore — it will NOT be committed.
# ============================================================

# --- App ---
NODE_ENV="development"
PORT="3000"
NEXTAUTH_URL="http://localhost:3000"

# --- Kubernetes ---
K8S_DEV_NAMESPACE="aigo-dev"
K8S_PROD_NAMESPACE="aigo-prod"
K8S_SYSTEM_NAMESPACE="aigo-system"
K8S_WORKER_NAMESPACE="aigo-workers"
REGISTRY_URL="localhost:5111"
IN_CLUSTER_REGISTRY_URL="k3d-aigo-registry:5000"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- Worker Concurrency ---
# WORKER_CONCURRENCY="3"                              # Global default for all queue workers
# WORKER_CONCURRENCY_EMBEDDING="5"                    # Per-queue override: embedding
# WORKER_CONCURRENCY_RETRIEVAL="5"                    # Per-queue override: retrieval
# WORKER_CONCURRENCY_SUMMARIZER="3"                   # Per-queue override: summarizer
# WORKER_CONCURRENCY_IMPORT_ORCHESTRATOR="1"          # Per-queue override: import-orchestrator
# WORKER_CONCURRENCY_FILE_PROCESSING="3"              # Per-queue override: file-processing
# WORKER_CONCURRENCY_FILE_ANALYSIS="3"                # Per-queue override: file-analysis

# --- File Storage (defaults to <project>/.data/storage) ---
# FILE_STORAGE_PATH=""

# --- Builtin Services (URLs) ---
BUILTIN_SUPABASE_URL="http://localhost:54321"
BUILTIN_QDRANT_URL="http://localhost:6333"
BUILTIN_POSTHOG_URL="http://localhost:8100"
BUILTIN_N8N_URL="http://localhost:5678"
BUILTIN_MINIO_URL="http://localhost:9000"
BUILTIN_METABASE_URL="http://localhost:3001"
BUILTIN_MEILISEARCH_URL="http://localhost:7700"
BUILTIN_KEYCLOAK_URL="http://localhost:8180"

# --- Testing (Playwright) ---
BASE_URL="http://localhost:3000"

# ----------------------------------------------------------
# Secrets
# ----------------------------------------------------------

# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/aigo?schema=public"

# --- Auth ---
NEXTAUTH_SECRET="<random-secret>"
ENCRYPTION_KEY="<64-char-hex-string>"

# --- AI / LLM ---
OPENROUTER_API_KEY="<your-openrouter-api-key>"

# --- Platform Services (Keys & Credentials) ---
BUILTIN_SUPABASE_ANON_KEY="<your-supabase-anon-key>"
BUILTIN_SUPABASE_SERVICE_ROLE_KEY="<your-supabase-service-role-key>"
# BUILTIN_QDRANT_API_KEY=""
# BUILTIN_POSTHOG_API_KEY=""
# BUILTIN_N8N_API_KEY=""
BUILTIN_MINIO_ROOT_USER="minioadmin"
BUILTIN_MINIO_ROOT_PASSWORD="minioadmin"
# BUILTIN_METABASE_API_KEY=""
# BUILTIN_MEILISEARCH_API_KEY=""
BUILTIN_KEYCLOAK_ADMIN_USER="admin"
BUILTIN_KEYCLOAK_ADMIN_PASSWORD="admin"
