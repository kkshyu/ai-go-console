# ============================================================
# AI Go Console - Environment Variables
# ============================================================
# Copy non-secret defaults to .env:
#   cp .env.example .env  (then remove the secrets section)
# Copy secrets to .env.local:
#   cp .env.example .env.local  (then fill in real values)
# ============================================================

# === Non-secret defaults (copy to .env) ===

# App
NODE_ENV="development"
PORT="3000"
NEXTAUTH_URL="http://localhost:3000"

# Database host (connection string in .env.local)
PLATFORM_PG_HOST="localhost"
PLATFORM_PG_PORT="5432"

# Kubernetes namespaces
K8S_DEV_NAMESPACE="aigo-dev"
K8S_PROD_NAMESPACE="aigo-prod"
K8S_SYSTEM_NAMESPACE="aigo-system"
K8S_WORKER_NAMESPACE="aigo-workers"

# Docker registry
REGISTRY_URL="localhost:5111"

# Redis
REDIS_URL="redis://localhost:6379"

# Caddy Admin API
CADDY_ADMIN_URL="http://localhost:2019"

# Built-in Supabase URL
PLATFORM_SUPABASE_URL="http://localhost:54321"

# Testing (Playwright)
BASE_URL="http://localhost:3000"

# === Secrets (copy to .env.local) ===

# Database connection strings
DATABASE_URL="postgresql://user:password@localhost:5432/aigo?schema=public"
PLATFORM_PG_ADMIN_URL="postgresql://user:password@localhost:5432/postgres"

# Auth
NEXTAUTH_SECRET="<random-secret>"

# Encryption key for credentials (must be 64 char hex string)
ENCRYPTION_KEY="<64-char-hex-string>"

# OpenRouter API
OPENROUTER_API_KEY="<your-openrouter-api-key>"

# Built-in Supabase keys
PLATFORM_SUPABASE_ANON_KEY="<your-supabase-anon-key>"
PLATFORM_SUPABASE_SERVICE_ROLE_KEY="<your-supabase-service-role-key>"
