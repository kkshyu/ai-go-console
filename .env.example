# ============================================================
# AI Go Console - Environment Variables
# ============================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
# .env is in .gitignore — it will NOT be committed.
# ============================================================

# --- App ---
NODE_ENV="development"
PORT="3000"
NEXTAUTH_URL="http://localhost:3000"

# --- Kubernetes ---
K8S_DEV_NAMESPACE="aigo-dev"
K8S_PROD_NAMESPACE="aigo-prod"
K8S_SYSTEM_NAMESPACE="aigo-system"
K8S_WORKER_NAMESPACE="aigo-workers"
REGISTRY_URL="localhost:5111"
IN_CLUSTER_REGISTRY_URL="k3d-aigo-registry:5000"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- File Storage (defaults to <project>/.data/storage) ---
# FILE_STORAGE_PATH=""

# --- Platform Services (URLs) ---
PLATFORM_SUPABASE_URL="http://localhost:54321"
PLATFORM_QDRANT_URL="http://localhost:6333"
PLATFORM_POSTHOG_URL="http://localhost:8100"
PLATFORM_N8N_URL="http://localhost:5678"
PLATFORM_MINIO_URL="http://localhost:9000"
PLATFORM_METABASE_URL="http://localhost:3001"
PLATFORM_MEILISEARCH_URL="http://localhost:7700"
PLATFORM_KEYCLOAK_URL="http://localhost:8180"

# --- Testing (Playwright) ---
BASE_URL="http://localhost:3000"

# ----------------------------------------------------------
# Secrets
# ----------------------------------------------------------

# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/aigo?schema=public"

# --- Auth ---
NEXTAUTH_SECRET="<random-secret>"
ENCRYPTION_KEY="<64-char-hex-string>"

# --- AI / LLM ---
OPENROUTER_API_KEY="<your-openrouter-api-key>"

# --- Platform Services (Keys & Credentials) ---
PLATFORM_SUPABASE_ANON_KEY="<your-supabase-anon-key>"
PLATFORM_SUPABASE_SERVICE_ROLE_KEY="<your-supabase-service-role-key>"
# PLATFORM_QDRANT_API_KEY=""
# PLATFORM_POSTHOG_API_KEY=""
# PLATFORM_N8N_API_KEY=""
PLATFORM_MINIO_ROOT_USER="minioadmin"
PLATFORM_MINIO_ROOT_PASSWORD="minioadmin"
# PLATFORM_METABASE_API_KEY=""
# PLATFORM_MEILISEARCH_API_KEY=""
PLATFORM_KEYCLOAK_ADMIN_USER="admin"
PLATFORM_KEYCLOAK_ADMIN_PASSWORD="admin"
