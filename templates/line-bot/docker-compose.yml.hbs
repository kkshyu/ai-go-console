services:
  app:
    build: .
    image: aigo-{{orgSlug}}-{{slug}}-prod
    container_name: aigo-{{orgSlug}}-{{slug}}-prod
    restart: unless-stopped
    ports:
      - "{{prodPort}}:3000"
    environment:
      PORT: "3000"
      NODE_ENV: "production"
      {{#each envVars}}
      {{@key}}: "{{this}}"
      {{/each}}
