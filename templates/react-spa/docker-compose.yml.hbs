services:
  app:
    build: .
    image: aigo-{{orgSlug}}-{{slug}}-prod
    container_name: aigo-{{orgSlug}}-{{slug}}-prod
    restart: unless-stopped
    ports:
      - "{{prodPort}}:80"
    {{#if envVars}}
    environment:
      {{#each envVars}}
      {{@key}}: "{{this}}"
      {{/each}}
    {{/if}}
